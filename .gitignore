/target/
**/*.rs.bk
.DS_Store
__pycache__/
*.pyc

# Validation harness per-run JSONL traces (the markdown report at
# spec/validation-log.md is the checked-in artifact; per-run traces
# are local-only).
spec/validation-results-*.jsonl

# Cross-language comparison harness — per-run JSONL traces and the
# per-run markdown reports are local-only history; the latest-pointer
# markdown report at comp/log/comparison-log.md is the checked-in summary.
comp/log/comparison-results-*.jsonl
comp/log/comparison-log-*.md

# Cross-language harness — agent-driven run artifacts (the markdown
# report at comp/log/comparison-log.md is the checked-in summary).
comp/log/agent-inputs/
comp/log/agent-outputs*.json
comp/log/agent-results*.json
