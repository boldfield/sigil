import std.choose
import std.option

fn check_conflict(grid: MutArray[Int], target_idx: Int, i: Int, d: Int) -> Bool ![Mem, ArithError] {
  match i {
    81 => false,
    _ => {
      if i == target_idx {
        check_conflict(grid, target_idx, i + 1, d)
      } else {
        let row_i: Int = i / 9;
        let row_t: Int = target_idx / 9;
        let col_i: Int = i - row_i * 9;
        let col_t: Int = target_idx - row_t * 9;
        let same_row: Bool = row_i == row_t;
        let same_col: Bool = col_i == col_t;
        if same_row {
          if mut_array_get(grid, i) == d { true } else { check_conflict(grid, target_idx, i + 1, d) }
        } else {
          if same_col {
            if mut_array_get(grid, i) == d { true } else { check_conflict(grid, target_idx, i + 1, d) }
          } else {
            check_conflict(grid, target_idx, i + 1, d)
          }
        }
      }
    },
  }
}

fn try_at_cell(grid: MutArray[Int], idx: Int) -> Int ![Choose, Mem, ArithError] {
  let d: Int = perform Choose.choose(9);
  let digit: Int = d + 1;
  if check_conflict(grid, idx, 0, digit) {
    perform Choose.fail()
  } else {
    let _set: Unit = mut_array_set(grid, idx, digit);
    let result: Int = solve(grid, idx + 1);
    if result == 0 {
      let _undo: Unit = mut_array_set(grid, idx, 0);
      perform Choose.fail()
    } else {
      result
    }
  }
}

fn solve(grid: MutArray[Int], idx: Int) -> Int ![Choose, Mem, ArithError] {
  let _solve_dummy: Int = perform Choose.choose(1);
  if idx == 81 {
    mut_array_get(grid, 8)
  } else {
    if mut_array_get(grid, idx) != 0 {
      solve(grid, idx + 1)
    } else {
      try_at_cell(grid, idx)
    }
  }
}

