fn main() -> Int ![IO, Mem, ArithError] {
  let solved: Option[Int] = first_choice(solve_initial);
  match solved {
    Some(v) => { perform IO.println(int_to_string(v)); 0 },
    None => { perform IO.println("none"); 1 },
  }
}
